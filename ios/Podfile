platform :ios, '16.0'
$FirebaseSDKVersion = '10.28.0'


# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

pre_install do |installer|
  # firebase_messaging 14.x: FLTFirebaseMessagingPlugin.h içinde
  # "#import <Firebase/Firebase.h>" → non-modular header xcode hatası.
  # Xcode dosyayı doğrudan pub-cache'den okuduğu için orada yamalamalıyız.
  home = File.expand_path('~')
  pub_dev = File.join(home, '.pub-cache', 'hosted', 'pub.dev')
  Dir.glob("#{pub_dev}/firebase_messaging-*/ios/Classes/*.h").each do |header|
    content = File.read(header) rescue next
    next unless content.include?('#import <Firebase/Firebase.h>')
    patched = content.gsub('#import <Firebase/Firebase.h>', '#import <FirebaseMessaging/FirebaseMessaging.h>')
    File.write(header, patched)
    puts "✅ pre_install patched: #{header}"
  end
  # Sembolik link üzerinden de yama (garanti için)
  symlink_classes = File.join(File.dirname(__FILE__), '..', '.symlinks', 'plugins', 'firebase_messaging', 'ios', 'Classes')
  if Dir.exist?(symlink_classes)
    Dir.glob("#{symlink_classes}/*.h").each do |symlink_h|
      real = (File.realpath(symlink_h) rescue symlink_h)
      content = File.read(real) rescue next
      next unless content.include?('#import <Firebase/Firebase.h>')
      File.write(real, content.gsub('#import <Firebase/Firebase.h>', '#import <FirebaseMessaging/FirebaseMessaging.h>'))
      puts "✅ pre_install symlink patched: #{real}"
    end
  end
end


post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
    end
  end
  installer.pods_project.build_configurations.each do |config|
    config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
  end
end
